---

import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import Menu from '../components/ui/Menu.astro';

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=menu" />
		<meta name="generator" content={Astro.generator} />
		<title>Christian Mamplata</title>
	</head>
	<body class="bg-slate-200">
        <Header />
		<slot />
        <Menu />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
